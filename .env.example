SECRET_KEY=changeme
DATABASE_URL=postgresql+psycopg2://cartepro:cartepro@db:5432/cartepro
FLASK_ENV=development

# Stripe — récupérer depuis https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_example
STRIPE_PUBLIC_KEY=pk_test_example
STRIPE_WEBHOOK_SECRET=whsec_example
STRIPE_MONTHLY_PRICE_ID=price_exemple_mensuel
STRIPE_ANNUAL_PRICE_ID=price_exemple_annuel

# Email — récupérer depuis https://sendgrid.com
SENDGRID_API_KEY=SG.exemple
FROM_EMAIL=noreply@cartepro.ca

# URL du frontend (redirections après paiement Stripe)
APP_URL=http://localhost:3000

# Infrastructure
RATELIMIT_STORAGE_URI=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000
BACKUP_KEY=your-backup-key

# Admin (utilisé par flask seed-admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cartepro.ca
ADMIN_PASSWORD=changeme
